---
import Base from '../layouts/Base.astro';
import { config } from '../config';
const { product, upsell, delivery, legal } = config;
---
<Base>

  <!-- ===== HERO ===== -->
  <section class="bg-gradient-to-b from-pink-50 to-white pt-6 pb-10 px-4">
    <div class="max-w-lg mx-auto text-center">
      <div class="inline-block bg-accent text-white text-sm font-semibold px-4 py-1 rounded-full mb-4">
        ⚡ Акція до кінця дня
      </div>
      <h1 class="font-heading text-3xl md:text-5xl font-extrabold text-dark leading-tight mb-3">
        {product.name}
      </h1>
      <p class="text-lg text-muted mb-6">{product.tagline}</p>

      <div class="relative mb-6">
        <img src="/images/hero.jpg" alt={product.name}
          class="w-full max-w-sm mx-auto rounded-2xl shadow-lg" loading="eager" />
      </div>

      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="text-muted line-through text-xl">{product.oldPrice} {product.currency}</span>
        <span class="text-primary font-heading text-4xl font-extrabold">{product.price} {product.currency}</span>
      </div>

      <!-- Лічильник залишку -->
      <p class="text-sm text-red-600 font-semibold mb-4">
        🔥 Залишилось: <span id="stock-count">7</span> шт за акційною ціною
      </p>

      <a href="#order"
        class="block w-full bg-accent hover:bg-orange-600 text-white font-heading font-bold text-xl py-4 rounded-2xl transition-colors shadow-lg">
        Замовити зі знижкою →
      </a>
      <p class="text-xs text-muted mt-3">Доставка {delivery.carrier} · Оплата при отриманні</p>
    </div>
  </section>

  <!-- ===== ТАЙМЕР ===== -->
  <div class="bg-dark text-white text-center py-3 px-4">
    <span class="text-sm">⏰ Акційна ціна діє ще: </span>
    <span id="timer" class="font-heading font-bold text-accent text-lg">23:59:59</span>
  </div>

  <!-- ===== ПРОБЛЕМА ===== -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-lg mx-auto">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-center mb-8">
        Впізнаєте себе?
      </h2>
      <ul class="space-y-4">
        {["Незручно відчувати себе в улюблених речах", "Виступаючі складки псують будь-який образ",
          "Складно знайти білизну що тримає форму", "Хочеться виглядати стрункіше без дієт"].map(pain => (
          <li class="flex items-start gap-3 bg-red-50 rounded-xl p-4">
            <span class="text-red-500 text-xl flex-shrink-0">✗</span>
            <span class="text-dark">{pain}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== РІШЕННЯ ===== -->
  <section class="py-10 px-4 bg-pink-50">
    <div class="max-w-lg mx-auto text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold mb-3">Рішення є!</h2>
      <p class="text-muted mb-8">{product.name} вирішує всі ці проблеми одразу</p>
      <div class="grid grid-cols-2 gap-4">
        {[
          { icon: "✨", text: "Миттєвий ефект" },
          { icon: "💪", text: "Підтримує поставу" },
          { icon: "🌸", text: "Комфорт весь день" },
          { icon: "📐", text: "6 розмірів S–3XL" },
        ].map(item => (
          <div class="bg-white rounded-2xl p-4 shadow-sm text-center">
            <div class="text-3xl mb-2">{item.icon}</div>
            <p class="font-semibold text-sm text-dark">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== РОЗМІРИ ===== -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-lg mx-auto">
      <h2 class="font-heading text-2xl font-bold text-center mb-6">Таблиця розмірів</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-100">
        <table class="w-full text-sm text-center">
          <thead class="bg-primary text-white">
            <tr>
              <th class="py-3 px-2">Розмір</th>
              <th class="py-3 px-2">Обхват грудей</th>
              <th class="py-3 px-2">Обхват талії</th>
              <th class="py-3 px-2">Обхват стегон</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["S",   "80–84",  "60–64",  "86–90"],
              ["M",   "84–88",  "64–68",  "90–94"],
              ["L",   "88–92",  "68–72",  "94–98"],
              ["XL",  "92–96",  "72–76",  "98–102"],
              ["2XL", "96–100", "76–80",  "102–106"],
              ["3XL", "100–106","80–86",  "106–112"],
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-gray-50" : "bg-white"}>
                {row.map(cell => <td class="py-3 px-2 font-medium">{cell}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-muted mt-2 text-center">* всі розміри в сантиметрах</p>
    </div>
  </section>

  <!-- ===== ВІДГУКИ ===== -->
  <section class="py-10 px-4 bg-pink-50">
    <div class="max-w-lg mx-auto">
      <h2 class="font-heading text-2xl font-bold text-center mb-2">Відгуки покупців</h2>
      <p class="text-center text-muted text-sm mb-8">⭐⭐⭐⭐⭐ 4.9 з 5 (147 відгуків)</p>
      <div class="space-y-4">
        {[
          { name: "Оксана К.", city: "Київ", text: "Замовила розмір L, підійшов ідеально. Одягла під плаття — ефект вау! Чоловік не повірив очам.", stars: 5 },
          { name: "Марина В.", city: "Харків", text: "Вже 3 тижні ношу щодня. Дуже комфортно, не натирає, тримає форму весь день.", stars: 5 },
          { name: "Тетяна Р.", city: "Одеса", text: "Спочатку сумнівалась, але вирішила спробувати. Дуже задоволена! Беру ще одне.", stars: 5 },
        ].map(review => (
          <div class="bg-white rounded-2xl p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white font-bold text-sm">
                {review.name[0]}
              </div>
              <div>
                <p class="font-semibold text-dark text-sm">{review.name}</p>
                <p class="text-xs text-muted">{review.city}</p>
              </div>
              <span class="ml-auto text-yellow-400 text-sm">{"⭐".repeat(review.stars)}</span>
            </div>
            <p class="text-sm text-dark leading-relaxed">{review.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== UPSELL ===== -->
  {upsell.enabled && (
    <section class="py-10 px-4 bg-white">
      <div class="max-w-lg mx-auto">
        <div class="bg-gradient-to-r from-pink-500 to-primary rounded-2xl p-6 text-white text-center">
          <p class="text-sm font-semibold mb-1">🎁 СПЕЦІАЛЬНА ПРОПОЗИЦІЯ</p>
          <h3 class="font-heading text-xl font-bold mb-2">Додай {upsell.product}</h3>
          <p class="text-pink-100 text-sm mb-4">{upsell.discount}</p>
          <div class="flex items-center justify-center gap-2 mb-4">
            <span class="line-through text-pink-200">{upsell.price * 2} грн</span>
            <span class="text-3xl font-heading font-bold">{upsell.price} грн</span>
          </div>
          <label class="flex items-center gap-3 bg-white/20 rounded-xl p-3 cursor-pointer">
            <input type="checkbox" id="upsell-check" class="w-5 h-5 rounded" />
            <span class="text-sm font-medium">Так, додати {upsell.product} за {upsell.price} грн</span>
          </label>
        </div>
      </div>
    </section>
  )}

  <!-- ===== FAQ ===== -->
  <section class="py-10 px-4 bg-gray-50">
    <div class="max-w-lg mx-auto">
      <h2 class="font-heading text-2xl font-bold text-center mb-8">Часті запитання</h2>
      <div class="space-y-3" id="faq">
        {[
          { q: "Як обрати розмір?", a: "Орієнтуйтесь на таблицю розмірів вище. Якщо ви між розмірами — беріть більший для комфорту." },
          { q: "Як швидко доставляють?", a: "Нова Пошта доставляє по Україні 1-3 робочих дні. Відправляємо наступного дня після замовлення." },
          { q: "Як оплатити?", a: "Накладеним платежем при отриманні на Новій Пошті. Або онлайн карткою зі знижкою 5%." },
          { q: "Чи можна повернути?", a: `Так, протягом 14 днів згідно ${legal.returns}. Повернення за наш рахунок.` },
          { q: "Чи є у вас сертифікат?", a: "Так, вся продукція сертифікована відповідно до українських стандартів якості." },
        ].map((item, i) => (
          <details class="bg-white rounded-xl px-5 py-4 cursor-pointer group">
            <summary class="font-semibold text-dark flex justify-between items-center list-none">
              {item.q}
              <span class="text-primary text-lg ml-2">+</span>
            </summary>
            <p class="text-muted text-sm mt-3 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ФОРМА ЗАМОВЛЕННЯ ===== -->
  <section id="order" class="py-12 px-4 bg-gradient-to-b from-white to-pink-50">
    <div class="max-w-lg mx-auto">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-center mb-2">
        Замовити {product.name}
      </h2>
      <div class="flex items-center justify-center gap-3 mb-8">
        <span class="text-muted line-through text-lg">{product.oldPrice} грн</span>
        <span class="text-primary font-heading text-3xl font-extrabold">{product.price} грн</span>
      </div>

      <form id="order-form" class="bg-white rounded-2xl p-6 shadow-md space-y-4">
        <div>
          <label class="block text-sm font-semibold text-dark mb-1">Ваше ім'я *</label>
          <input type="text" name="name" placeholder="Наприклад: Оксана"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-primary"
            required />
        </div>
        <div>
          <label class="block text-sm font-semibold text-dark mb-1">Номер телефону *</label>
          <input type="tel" name="phone" placeholder="+380 XX XXX XX XX"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-primary"
            required />
        </div>
        <div>
          <label class="block text-sm font-semibold text-dark mb-1">Розмір *</label>
          <select name="size"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-primary"
            required>
            <option value="">Оберіть розмір</option>
            {product.sizes.map(s => <option value={s}>{s}</option>)}
          </select>
        </div>

        <button type="submit"
          class="w-full bg-accent hover:bg-orange-600 text-white font-heading font-bold text-xl py-4 rounded-2xl transition-colors">
          Замовити за {product.price} грн →
        </button>
        <p class="text-xs text-muted text-center">
          Натискаючи кнопку, ви погоджуєтесь з <a href={legal.ofertaUrl} class="underline">договором оферти</a>
        </p>
      </form>

      <!-- Success message -->
      <div id="success-msg" class="hidden text-center py-8">
        <div class="text-5xl mb-4">🎉</div>
        <h3 class="font-heading text-2xl font-bold text-dark mb-2">Дякуємо за замовлення!</h3>
        <p class="text-muted">Наш менеджер зв'яжеться з вами протягом 30 хвилин</p>
      </div>

      <div class="flex justify-center items-center gap-6 mt-6 opacity-60">
        <img src="/images/nova-poshta.png" alt="Нова Пошта" class="h-6" />
        <img src="/images/liqpay.png" alt="LiqPay" class="h-6" />
      </div>
    </div>
  </section>

  <!-- ===== ФУТЕР ===== -->
  <footer class="bg-dark text-white py-8 px-4">
    <div class="max-w-lg mx-auto text-center">
      <p class="text-sm text-gray-400 mb-2">{legal.fop}</p>
      <div class="flex justify-center gap-4 text-sm">
        <a href={legal.ofertaUrl} class="text-gray-400 hover:text-white underline">Договір оферти</a>
        <span class="text-gray-600">·</span>
        <span class="text-gray-400">Повернення: {legal.returns}</span>
      </div>
    </div>
  </footer>

</Base>

<script define:vars={{ workerUrl: config.form.workerUrl, productName: config.product.name }}>
  // Таймер зворотного відліку
  function startTimer() {
    const end = new Date();
    end.setHours(23, 59, 59, 0);
    const tick = () => {
      const diff = end - new Date();
      if (diff <= 0) return;
      const h = String(Math.floor(diff / 3600000)).padStart(2, '0');
      const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
      const s = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
      const el = document.getElementById('timer');
      if (el) el.textContent = `${h}:${m}:${s}`;
    };
    tick();
    setInterval(tick, 1000);
  }
  startTimer();

  // Форма замовлення
  document.getElementById('order-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const upsellCheck = document.getElementById('upsell-check');

    btn.textContent = 'Відправляємо...';
    btn.disabled = true;

    const data = {
      name: form.name.value,
      phone: form.phone.value,
      size: form.size?.value,
      product: productName,
      upsell: upsellCheck?.checked ? upsellCheck.closest('label')?.textContent?.trim() : null,
      source: window.location.href,
    };

    try {
      const res = await fetch(workerUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (json.ok) {
        form.classList.add('hidden');
        document.getElementById('success-msg')?.classList.remove('hidden');
        // Meta Pixel — Purchase event
        if (window.fbq) fbq('track', 'Purchase', { value: 890, currency: 'UAH' });
        // TikTok Pixel
        if (window.ttq) ttq.track('PlaceAnOrder');
      } else {
        btn.textContent = 'Спробуйте ще раз';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Помилка. Зателефонуйте нам';
      btn.disabled = false;
    }
  });
</script>
